# Third-party source trees fetched by port scripts — never committed.
build/third_party/

# Sysroot and intermediate build artifacts for ports.  All regenerated
# by the port scripts + build.sh.
build/sysroot/
build/mbedtls_objs/

# Toolchain tree (Phase E output, when present).
toolchain/

# Toolchain build scratch — regenerated by scripts/build-toolchain.sh.
build/binutils-2.42-build/
build/gcc-14.2.0-build/

# Claude Code local state (session settings, scheduled task locks).
# Never commit — contains absolute paths and tool-internal state.
.claude/

# Build scratch logs.  Regenerated each invocation; not worth tracking.
build.log
build/build.log
build/*_meson.log
build/*_ninja.log
build/*_install.log
build/xkb_install.debugfs
libstdcxx.log
toolchain-rebuild.log

# Editor swap files.
*.kate-swp

# Port build trees — these are intermediate cmake/meson/ninja
# scratch.  Regenerated each run; 100+ MB of noise per port.
build/sdl3_build/
build/foot_build/
build/fcft_build/
build/libinput_build/
build/tinywl_build/
build/wlroots_build/

# Port-specific scratch logs.
build/port_*.log
build/sdl3_*.log
build/foot_*.log
build/fcft_*.log

# Disk images — regenerated by the build; both exceed GitHub's 100 MB cap.
build/ext2.img
build/disk.img
