Add x86_64-pc-makaos target to binutils 2.42.

Registers "makaos" as a recognized OS in config.sub, routes the x86_64
target through the existing ELF64 path, and wires a default ELF
emulation name (elf_x86_64_makaos) that reuses standard elf_x86_64.sh
with MakaOS-appropriate defaults.

Signed-off-by: MakaOS <noreply@makaos>

diff --git a/config.sub b/config.sub
--- a/config.sub
+++ b/config.sub
@@ -1723,7 +1723,7 @@ case $os in
 	# Now accept the basic system types.
 	# The portable systems comes first.
 	# Each alternative MUST end in a * to match a version number.
-	gnu* | android* | bsd* | mach* | minix* | genix* | ultrix* | irix* \
+	gnu* | android* | bsd* | mach* | minix* | genix* | ultrix* | irix* | makaos* \
 	     | *vms* | esix* | aix* | cnk* | sunos | sunos[34]* \
 	     | hpux* | unos* | osf* | luna* | dgux* | auroraux* | solaris* \
 	     | sym* |  plan9* | psp* | sim* | xray* | os68k* | v88r* \
diff --git a/bfd/config.bfd b/bfd/config.bfd
--- a/bfd/config.bfd
+++ b/bfd/config.bfd
@@ -652,6 +652,11 @@ case "${targ}" in
     targ_selvecs="iamdll_vec x86_64_elf64_vec x86_64_pei_vec i386_pei_vec i386_elf32_vec iamdll_vec x86_64_mach_o_vec"
     want64=true
     ;;
+  x86_64-*-makaos*)
+    targ_defvec=x86_64_elf64_vec
+    targ_selvecs="i386_elf32_vec"
+    want64=true
+    ;;
   x86_64-*-mingw* | x86_64-*-pe | x86_64-*-pep | x86_64-*-cygwin)
     targ_defvec=x86_64_pe_vec
     targ_selvecs="x86_64_pei_vec x86_64_elf64_vec i386_pe_vec i386_pei_vec i386_elf32_vec iamdll_vec x86_64_mach_o_vec"
diff --git a/gas/configure.tgt b/gas/configure.tgt
