   i386-*-cygwin*)
    case ${cpu} in

diff --git a/ld/configure.tgt b/ld/configure.tgt
--- a/ld/configure.tgt
+++ b/ld/configure.tgt
@@ -998,6 +998,10 @@ x86_64-*-elf* | x86_64-*-rtems* | x86_64-*-fuchsia* | x86_64-*-genode*)
 			targ_extra_emuls="elf_i386 elf32_x86_64 elf_iamcu"
 			targ_extra_libpath=$targ_extra_emuls
 			;;
+x86_64-*-makaos*)	targ_emul=elf_x86_64_makaos
+			targ_extra_emuls="elf_x86_64 elf_i386"
+			targ_extra_libpath=$targ_extra_emuls
+			;;
 x86_64-*-haiku*)	targ_emul=elf_x86_64_haiku
 			targ_extra_emuls="elf_x86_64 elf_i386_haiku"
 			;;
diff --git a/ld/emulparams/elf_x86_64_makaos.sh b/ld/emulparams/elf_x86_64_makaos.sh
new file mode 100644
--- /dev/null
+++ b/ld/emulparams/elf_x86_64_makaos.sh
@@ -0,0 +1,10 @@
+# elf_x86_64_makaos — MakaOS static-ELF, no dynamic linker.
+#
+# Thin override of elf_x86_64 that drops the interpreter reference
+# (we statically link everything today) and keeps all other defaults.
+
+source_sh ${srcdir}/emulparams/plt_unwind.sh
+source_sh ${srcdir}/emulparams/extern_protected_data.sh
+source_sh ${srcdir}/emulparams/dynamic_undefined_weak.sh
+source_sh ${srcdir}/emulparams/reloc_overflow.sh
+source_sh ${srcdir}/emulparams/elf_x86_64.sh
